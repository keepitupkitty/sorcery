select_features(){

 onf(){ local IFS="$STANDARD_IFS"
        [ ${FEATURE[$1]} ] && echo on || echo off; }

 feature_list(){
  for FEAT in ${!FEATURED[*]}
  do  echo "$FEAT"; onf $FEAT; onf $FEAT; echo "${FEATURED[$FEAT]}?"
  done
 }

  TITLE=$"Feature Menu"
     OK=$"Commit"
   HELP=$"[*]=on  [ ]=off"

 $DIALOG --ok-label "$OK" --no-cancel --item-help --separate-output \
         --title "$TITLE" --checklist "$HELP" 0 0 0  \
         $( feature_list )
}


feature_menu(){
 local REPLY feature
 if    REPLY="$( select_features )"; then
  sed -i '/FEATURE=/d 
          /FEATURE\[.*\]=/d' $LOCAL_CONFIG
  echo "FEATURE=()" >> $LOCAL_CONFIG
  FEATURE=()
  for feature in $REPLY
  do  FEATURE[$feature]=1; echo "FEATURE[$feature]=1" >> $LOCAL_CONFIG
  done
 fi
}


get_set_variable(){
 local VARIABLE
 if    VARIABLE="$( $DIALOG --ok-label "Commit" \
                            --inputbox "$3" 0 0 "$2" )"
 then
  if   grep -q   "$1="                   $LOCAL_CONFIG
  then sed  -i "s:$1=.*:$1=$VARIABLE:"   $LOCAL_CONFIG
  else echo            "$1=$VARIABLE" >> $LOCAL_CONFIG
  fi
  echo  "$VARIABLE"
 fi
}

