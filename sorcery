}


rate_menu(){

 while
  D_HELP=$"Default amount of seconds to wait for prompts to be answered"
  P_HELP=$"Maximum allowed days for unessential sorcery logs to exist"
  R_HELP=$"Maximum allowed old versions of sources and caches to keep"
  S_HELP=$"Maximim allowed seconds to await a patch to be generated"
  T_HELP=$"Maximum bytes per second for downloading"
  X_HELP=$"Minimum number of days old installed grimoires should be"
  H_HELP=$"Maximum percent of ccache cache for keeping old ccaches"
  I_HELP=$"Maximum percent of source cache to for keeping old sources"
  M_HELP=$"Maximum megabytes per second throughput for I/O"

  COMMAND=$(
  $DIALOG --item-help --ok-label Select --cancel-label Exit \
          --title "Rate Menu" --menu "" 0 40 0 \
          Expire       "Days    $EXPIRE"            "$P_HELP" \
          Lag          "Days    $LAG"               "$X_HELP" \
          Ccache_Keep  "Percent $CCACHE_KEEP"       "$H_HELP" \
          Patch        "Delay   $PATCH_DELAY"       "$S_HELP" \
          Prompt       "Delay   $PROMPT_DELAY"      "$D_HELP" )
 do
  case $COMMAND in
    Ccache_Keep) set_ccache_keep  ;;
         Expire) expire_menu      ;;
            Lag) set_grimoire_lag ;;
          Patch) set_patch_delay  ;;
         Prompt) set_prompt_delay ;;
  esac
 done
}


set_expire(){
 EXPIRE="$(
 get_set_variable "EXPIRE" "${EXPIRE:-365}" \
 $"# of days before unessential logs are removed?"
 )"
}


set_event_expire(){
 EVENT_EXPIRE="$(
  get_set_variable "EVENT_EXPIRE" "${EVENT_EXPIRE:-180}" \
  $"# of days before old event logs are removed?"
 )"
}


expire_menu(){

 while
  D_HELP=$"Default expire time is used when specific expiration is not set"
  E_HELP=$"$EVENT_LOGS		Event logs"

  COMMAND=$(
  $DIALOG --item-help --ok-label Select --cancel-label Exit \
          --title "Expire Menu" --menu "" 0 40 0   \
          Default "days $EXPIRE"         "$D_HELP" \
          Event   "days $EVENT_EXPIRE"   "$E_HELP" )
 do
  case $COMMAND in
   Default) set_expire ;;
   Event)   set_event_expire ;;
  esac
 done
}


select_cpref(){

 TITLE="Please select a compiler preference file"

 $DIALOG --title "$TITLE" --menu "from  $CPREF_DIR" 0 0 0 \
         $( find $CPREF_DIR -type f -printf "%P\nfile\n" )

}


delete_cpref(){ rm -f $CPREF_DIR/$PREF; }

copy_cpref(){
 NPREF=$( $DIALOG --inputbox "Enter a new name please." 0 0 )
 cp $CPREF_DIR/$PREF $CPREF_DIR/$NPREF
}


edit_cpref(){ ${EDITOR:=nano} $CPREF_DIR/$PREF; }


default_cpref(){
 rm -f       $CPREF_DIR/default
 ln -s $PREF $CPREF_DIR/default
}


compile_menu(){

 while
   HELP=$"Create files which specify what compiler and optimizations to use"
  TITLE=$"Compiler Preference Menu"

  COMMAND=$(
  $DIALOG --item-help --ok-label Select --cancel-label Exit \
          --title "$TITLE" --menu "$HELP" 0 0 0  \
   Copy   "existing compiler preference file" "" \
   Delete "existing compiler preference file" "" \
   Edit   "existing compiler preference file" "" \
   Select "default  compiler preference file" "" )
 do
    
  PREF=$( select_cpref ) &&
  case $COMMAND in
     Copy) copy_cpref    ;;
   Delete) delete_cpref  ;;
     Edit) edit_cpref    ;;
   Select) default_cpref ;;
  esac
 done
}


set_cache1(){

 if SOURCE_CACHE[1]=$(
     $DIALOG --ok-label "Commit" --inputbox \
     $"Please enter a directory to check for sources" 0 0 "${SOURCE_CACHE[1]}" )
 then
  sed  -i  "/SOURCE_CACHE\[1\]=/d"                  $LOCAL_CONFIG
  if [[ -n ${SOURCE_CACHE[1]}  ]]; then
   echo "[ $BASH_VERSION ] && SOURCE_CACHE[1]=${SOURCE_CACHE[1]}" >> $LOCAL_CONFIG
  fi
 fi
}


set_repo1(){

 if SOURCE_REPOSITORY[1]=$(
     $DIALOG --ok-label Commit --inputbox \
     $"Please enter a FTP or HTTP URL to use as the first additional source repository" \
     0 0 "${SOURCE_REPOSITORY[1]}" )
 then
  sed    -i  "/SOURCE_REPOSITORY\[1\]=/d"                       $LOCAL_CONFIG
  if   [[ -n ${SOURCE_REPOSITORY[1]}  ]]
  then echo "[ $BASH_VERSION ] && SOURCE_REPOSITORY[1]=${SOURCE_REPOSITORY[1]}" >> $LOCAL_CONFIG
  fi
 fi
}


set_repo2(){

 if SOURCE_REPOSITORY[2]=$(
    $DIALOG --ok-label Commit --inputbox \
    $"Please enter a FTP or HTTP URL to use as the second additional source repository" \
    0 0 "${SOURCE_REPOSITORY[2]}" )
 then
  sed    -i  "/SOURCE_REPOSITORY\[2\]=/d"                       $LOCAL_CONFIG
  if   [[ -n ${SOURCE_REPOSITORY[2]} ]]
  then echo   "[ $BASH_VERSION ] && SOURCE_REPOSITORY[2]=${SOURCE_REPOSITORY[2]}" >> $LOCAL_CONFIG
  fi
 fi
}


source_menu(){

 while
  S1_HELP=$"Specify first  additional source cache      to check"
  R1_HELP=$"Specify first  additional source repository to check"
  R2_HELP=$"Specify second additional source repository to check"
     SC1="${SOURCE_CACHE[1]}"
     SR1="${SOURCE_REPOSITORY[1]}"
     SR2="${SOURCE_REPOSITORY[2]}"

   TITLE=$"Source Cache and Repository Menu"
    HELP=$"Load retrieves sources in the following order:

\${SOURCE_CACHE[0]}
\${SOURCE_CACHE[1]}
\${SOURCE_REPOSITORY[1]}
\${SDELTA_REPOSITORY[0]}
\${SOURCE_REPOSITORY[2]}
\${URL}
\${SOURCE_REPOSITORY[0]}"

      OK=$"Select"
  CANCEL=$"Exit"

  COMMAND=$(
   $DIALOG --item-help --ok-label "$OK" --cancel-label "$CANCEL" \
           --title "$TITLE" --menu "$HELP" 0 0 0 \
   Cache1      "$SC1" "$S1_HELP" \
   Repository1 "$SR1" "$R1_HELP" \
   Repository2 "$SR2" "$R2_HELP" )
 do
  case $COMMAND in
        Cache1) set_cache1 ;;
   Repository1) set_repo1  ;;
   Repository2) set_repo2  ;;
  esac
 done

}


e_feature_menu(){

 while
  C_HELP=$"Select options that effect compilation and linking"
  D_HELP=$"The parameters to pass to date when setting a date"
  L_HELP=$"Select methods and order of method execution for load"
  R_HELP=$"Select a level of savings to justify downloading from the ppr"
  S_HELP=$"The email address where log can be sent"

  T_HELP=$"Specify additional source caches and repositories"
  T_LINE="[${SOURCE_CACHE[1]}] [${SOURCE_REPOSITORY[1]}] [${SOURCE_REPOSITORY[2]}]"

   TITLE=$"Extended Feature Menu"
      OK=$"Select"
  CANCEL=$"Exit"
      PT=$"per tarball"
  DCPREF="$( stat -c "%N"  $CPREF_DIR/default )"

  COMMAND=$(
   $DIALOG --item-help --ok-label "$OK" --cancel-label "$CANCEL" \
           --title "$TITLE" --menu "" 0 0 0 \
   Compiler "$DCPREF"             "$C_HELP" \
   Date     "$DATE_OPTS"          "$D_HELP" \
   Save     "${PPR_SAVE:-no} $PT" "$R_HELP" \
   Sorcerer "$SORCERER"           "$S_HELP" \
   Source   "$T_LINE"             "$T_HELP" \
   Load     "$LOAD_METHOD"        "$L_HELP" )
 do
  case $COMMAND in
