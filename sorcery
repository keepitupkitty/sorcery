export  TEXTDOMAIN=${0##*/}
export  TEXTDOMAINDIR=/usr/share/locale

load_menu(){
 TITLE=$"Load Method Menu"
 MHELP=$"Please create the order for load methods.
Default: $LOAD_DEFAULT
Previous: $LOAD_METHOD
"

 confirm_hosts(){
  local HELP="Without the hosts method
many sources will be difficult
if not impossible to download.
Method: $LOAD_METHOD
Is this correct?"
  [[ $LOAD_METHOD =~ hosts ]] ||
  $DIALOG --nocancel --yesno "$HELP" 0 0
 }

 method_list(){
  find /usr{,/local}/libexec/sorcery/load.d/ -type f -not -empty 2>/dev/null |
  while read; do
   . $REPLY
   basename $REPLY
   if ready; then echo $"Method ready"; else echo $"Method not ready"; fi
   echo "$HELP"
  done
 }
  
 PREVIOUS=$LOAD_METHOD
 LOAD_METHOD=

 while
  COMMAND=$(
   $DIALOG --item-help --ok-label $"Select" --cancel-label $"Exit" \
           --title "$TITLE" --menu "${MHELP}Current: $LOAD_METHOD" 20 75 10 \
           $( method_list ) )
 do
  if [[ $LOAD_METHOD ]]
  then   LOAD_METHOD+=" $COMMAND"
  else   LOAD_METHOD="$COMMAND"
  fi
 done

 if [[    $LOAD_METHOD ]] && confirm_hosts; then
  sed -i '/LOAD_METHOD/d' $LOCAL_CONFIG
  echo "LOAD_METHOD=\"$LOAD_METHOD\"" >> $LOCAL_CONFIG
 else LOAD_METHOD=$PREVIOUS
 fi
}

edit_queue(){
 local OLD="$TMP_DIR/queue/old$$$RANDOM"
 local NEW="$TMP_DIR/queue/new$$$RANDOM"

 mkdir_p "$1"
 find ${FIND_FOLLOW_SYMBOLIC_LINKS} "$1" -maxdepth 1 -mindepth 1 \
                 -type f      -newer /proc/version \
                 -printf "%f\n"  2>/dev/null       |
 tee $OLD >      $NEW
 ${EDITOR:=nano} $NEW

 sed "s:^:$1/:" $OLD | xargs -r --max-lines=256 rm -f

 pipe_queue "$1" "" < "$NEW"
#pipe_queue "$1" "" $RAINEN < "$NEW"
 rm    -f   "$OLD"            "$NEW"
}

select_role(){
 local CLVL=1
 local ROLES NROLE OROLE

 trim_roles(){
  view_index role     |
  sed  "s:${TAB}.*::" |
  grep "$NROLE"       |
  cut -d / -f-$CLVL   |
  LC_ALL=C sort -u
 }

 while
  OROLE="$NROLE"
  if     NROLE="$( 
   $DIALOG --default-item  "$role" --ok-label Accept --cancel-label Exit \
           --title $"Role Selection Menu" --menu "" 0 70 10 \
                   $( trim_roles | sed "aRole" ) )"
  then
   (( CLVL++ ))
   if   [ "$NROLE" == "$OROLE"          ] ||
        [ "$NROLE" == "$( trim_roles )" ]
   then false
   fi      
  else
   unset NROLE
   false
  fi
 do :
 done
 [[ -n $NROLE ]] &&
 echo "$NROLE"
}


evaluate(){ (

 tail_line(){
  local CX=$( echo "$1" | wc -l )

  if   (( CX > 5 ))
  then echo -n "... "
  fi

  echo "$1" |
  tail -n 5 |
  tr '\n' ' '
 }


 select_gcc_pref(){

  if   PREF=$( select_cpref )
  then mkdir          $CPREF_LOGS
       echo "$PREF" > $CPREF_LOGS/$1
  else rm -f          $CPREF_LOGS/$1
  fi
 }


 while
  SPELL="$1"
  spell_in_grimoire
  run_details

  A_HELP=$"Add $1 to cast queue?"
  C_HELP=$"Configure or reconfigure this spell the spells it requires."
  G_HELP=$"Select compiler preference for this spell."
  N_HELP=$"Display spells that $1 requires that are not already installed?"
  R_HELP=$"Display spells that $1 requires?"
  V_HELP=$"Display verbose description of $1?"

   TITLE=$"Evaluating $1	$VERSION"
      OK=$"Select"
  CANCEL=$"Exit"

  ALINE=$"Available Version:  $VERSION"

  if   [[ -d $CONFIG_LOGS/$1 ]]
  then CLINE="already configured"
  else CLINE="not yet configured"
  fi

  PL=$CPREF_LOGS/$1

  if   [[ -f      $PL ]]
  then GLINE="$(< $PL )"
  else GLINE="default"
  fi
 
  if   [[ -z $RLINE ]] ||
       [[ -z $NLINE ]]
  then
    REQS="$( echo "$1" | augur req arof )"
     RNI="$( echo "$1" | augur req arofni )"
   RLINE="$( tail_line "$REQS" )"
   NLINE="$( tail_line "$RNI"  )"
  fi

  VERBOSE="$( long_description $1 )"

  VLINE="$( echo "$VERBOSE" |
            tail -n +3      |
            tr   '\n' ' '   |
            cut  -c1-45
          ) ..."

  COMMAND=$(
   $DIALOG --item-help --ok-label "$OK" --cancel-label "$CANCEL" \
           --title "$TITLE" --menu "${SHORT:-$DESC}" 0 0 0 \
           Add       "$ALINE" "$A_HELP" \
           Configure "$CLINE" "$C_HELP" \
           GCC       "$GLINE" "$G_HELP" \
           Requires  "$RLINE" "$R_HELP" \
           RNI       "$NLINE" "$N_HELP" \
           Verbose   "$VLINE" "$V_HELP" )
 do
  case $COMMAND in
   Add) echo "$1" | pipe_queue "$CAST_QUEUE" ""
#  Add) echo "$1" | pipe_queue "$CAST_QUEUE" "" $RAINEN
        $DIALOG --msgbox "$1 added to cast queue." 0 0
        break ;;

   Configure) augur forget conf "$1"
              augur forget opts "$1"
              augur configure   "$1"
              unset RLINE NLINE ;;

   GCC) select_gcc_pref $1 ;;

   RNI)      echo "$RNI"     | $PAGER ;;
   Requires) echo "$REQS"    | $PAGER ;;
   Verbose)  echo "$VERBOSE" | $PAGER ;;
  esac
 done
) }


add_spells(){
 local role

 ADD_KEY="Spell  Installed/Requirements  Configured  Traits"

 while role="$( select_role )"; do
  while
   TITLE="Select spell to examine or install please"
    HELP="Role: $role\n$ADD_KEY"
   SPELL="$( show_role     "$role" |
             generic_menu "$TITLE" Commit Cancel "$HELP"
           )"
   [[ -n      $SPELL ]]
  do evaluate $SPELL
  done
 done
}


file_list(){
 find  ${FIND_FOLLOW_SYMBOLIC_LINKS} $1 -type f |
 xargs --max-lines=64  file |
 tr    -s ' '               |
 cut   -d ' '  -f1-2        |
 sed   "s:.*[/]::;s,: ,\n,"
}


file_menu(){
 echo  $1/$( \
 $DIALOG --title "Please select a file." --menu  "" 0 0 0 $( file_list $1 ) )
}


remove_lone(){

 lone_list(){
  export LC_ALL=C

  echo Spell
  echo "Age  Opt  Size"
  echo off
  echo Description

  [[ -n $NL ]] &&
  echo "$NL" |
  while read SPELL; do

   if   [[ -f $DISPEL_QUEUE/$SPELL ]]
   then STATUS=on
   else STATUS=off
   fi

   OLD=$( stat "-c%Y" $VERSION_INDEX/$SPELL )

   (( AGE = NOW - OLD   ))
   (( AGE = AGE / 86400 ))

   if   (( AGE < 10  )); then AGE="  $AGE"
   elif (( AGE < 100 )); then AGE=" $AGE"
   fi

   SIZE="$( echo "$SPELL" | spell_size )"
   SIZE="${SIZE%$TAB*}"
   if   (( SIZE >  4194304 ))
   then (( SIZE /= 1048576 )); PSIZE="MB"
   elif (( SIZE >  4096    ));
   then (( SIZE /= 1024    )); PSIZE="KB"
   else                        PSIZE=" B"
   fi
   if   (( SIZE < 10   )); then PSIZE+='    '
   elif (( SIZE < 100  )); then PSIZE+='   '
   elif (( SIZE < 1000 )); then PSIZE+='  '
                           else PSIZE+=' '
   fi

   echo              "$SPELL"
   echo -n           "${AGE:-9999}       "
#  trait_of          "$SPELL"
   echo              "$PSIZE$SIZE"
   echo              "$STATUS"
   short_description "$SPELL"
  done

  [[ -n $NA ]] &&
  echo "$NA" |
  while read SPELL; do

   if   [[ -f $DISPEL_QUEUE/$SPELL ]]
   then STATUS=on
   else STATUS=off
   fi

   OLD=$( stat "-c%Y" $VERSION_INDEX/$SPELL )

   (( AGE = NOW - OLD   ))
   (( AGE = AGE / 86400 ))

   if   (( AGE < 10  )); then AGE="  $AGE"
   elif (( AGE < 100 )); then AGE=" $AGE"
   fi

   SIZE="$( echo "$SPELL" | spell_size )"
   SIZE="${SIZE%$TAB*}"
   if   (( SIZE >  4194304 ))
   then (( SIZE /= 1048576 )); PSIZE="MB"
   elif (( SIZE >  4096    ));
   then (( SIZE /= 1024    )); PSIZE="KB"
   else                        PSIZE=" B"
   fi
   if   (( SIZE < 10   )); then PSIZE+='    '
   elif (( SIZE < 100  )); then PSIZE+='   '
   elif (( SIZE < 1000 )); then PSIZE+='  '
                           else PSIZE+=' '
   fi

   echo              "$SPELL"
   echo -n           "${AGE:-9999}  Opt  "
#  trait_of          "$SPELL"
   echo              "$PSIZE$SIZE"
   echo              "$STATUS"
   short_description "$SPELL"
  done
 }

  L="$(        lone )"
 NL="$( echo "$LF$LF$SL$LF$SA$LF$L"       | sort | uniq -u )"
 SL="$L$LF$L"

  A="$( almost_lone )"
 NA="$( echo "$LF$LF$SA$LF$SL$LF$A$LF$NL" | sort | uniq -u )"
 SA="$A$LF$A"

 if [[ -z $NL ]] && [[ -z $NA ]]; then return; fi

 local IFS
 export IFS="$ENTER_IFS"
 $DIALOG --separate-output --item-help --nocancel --ok-label Select \
         --title "$TITLE" --checklist "$HELP" 20 70 10 $( lone_list ) |
 grep -vx Spell |
 pipe_queue "$DISPEL_QUEUE" ""
#pipe_queue "$DISPEL_QUEUE" "" $RAINEN

 remove_lone
}


remove_spells(){ (

 local SL
 local SA
 local NOW=$( date +%s )

 HELP=$"These spells may be selected for dispel.\n
Spells with Opt are still optionally required.\n
Dispelled Opt spells may cause recompilation\n
of other installed spells.\n

Arrow navigate.  Space toggles.  Enter executes.\n
 [*]=Remove\n
 [ ]=Keep"

  TITLE=$"Select spell to remove, please."

  remove_lone

) }


rebuild(){

 local SPELL

 rm    -rf $CAST_QUEUE
 mkdir -p  $CAST_QUEUE

 show_installed   |
 grep -vx sorcery |
 while read SPELL; do
  if   ! spell_unavailable "$SPELL"
  then echo                "$SPELL"
  fi
 done | pipe_queue "$CAST_QUEUE" ""
#done | pipe_queue "$CAST_QUEUE" "" $RAINEN
}


refresh(){

 local SPELL
 local HOW_OLD="Recompile spells that have been installed longer than how many days?"

 if          OLDER=$( $DIALOG --inputbox "$HOW_OLD" 0 0 ) &&
      [[ -n $OLDER ]]
 then
  rm    -rf $CAST_QUEUE
  mkdir -p  $CAST_QUEUE

  find $VERSION_INDEX -mtime +$OLDER |
  cut  -d '/'  -f6 |
  grep -vx sorcery |
  while read SPELL; do
   if   ! spell_unavailable "$SPELL"
   then echo                "$SPELL"
   fi
  done | pipe_queue "$CAST_QUEUE" ""
# done | pipe_queue "$CAST_QUEUE" "" $RAINEN
 fi
}


process_role(){
 # $1 = role
 # $2 = list of spells that should be installed

 [[ -n              $2  ]] &&
          echo      "$2" |
 pipe     show_role  "$1" |
 LC_ALL=C sort           |
          uniq  -d       | pipe_queue "$CAST_QUEUE" ""
#         uniq  -d       | pipe_queue "$CAST_QUEUE" "" $RAINEN

          echo      "$2" |
 pipe     show_role  "$1" |
 LC_ALL=C sort           |
          uniq  -u       |
 pipe     show_installed |
 LC_ALL=C sort           |
          uniq  -d       | pipe_queue "$DISPEL_QUEUE" ""
#         uniq  -d       | pipe_queue "$DISPEL_QUEUE" "" $RAINEN
}


select_spells(){
 local role

 make_checklist(){
  show_role "$1" |
  while read; do

   if   spell_installed "$REPLY"
   then ONOFF=on;  STATUS=installed
   else ONOFF=off; STATUS=available
   fi

   if   [[ -f   $CAST_QUEUE/$REPLY ]]; then ONOFF=on
   elif [[ -f $DISPEL_QUEUE/$REPLY ]]; then ONOFF=off
   fi

   echo              "$REPLY"
   echo -n           "$STATUS  "
   installed_ratio   "$REPLY"
   trait_of      "$REPLY"
   echo              "$ONOFF"
   short_description "$REPLY"
  done
 }


      ADD_KEY=$"Spell  Status  Installed/Requirements  Configured  Traits"
 SELECT_TITLE=$"Spell Selection Menu"
  SELECT_HELP=$"[*]=install  [ ]=remove\n$ADD_KEY"
         LIST=$"/tmp/.checklist.$RANDOM$RANDOM"

 while role="$( select_role )"; do
  ( echo "--title";         echo "$SELECT_TITLE"
    echo "--ok-label";      echo "Commit"
    echo "--cancel-label";  echo "Abort"
    echo "--item-help";     echo "--separate-output"
    echo "--checklist";     echo "Role: $role  $SELECT_HELP"
    echo "18";  echo  "72"; echo "10"
    make_checklist  $role
  ) | sed 's:^:":;s:$:":' > $LIST

  if   OUTLIST=$( $DIALOG --file $LIST )
  then process_role "$role" "$OUTLIST"
  fi
  rm -f $LIST
 done
}


software_menu(){

 while
  C_HELP=$"Select only uninstalled software to install"
  D_HELP=$"Select only   installed software to remove"
  S_HELP=$"Select any    available software for both installation and removal"
  Q_HELP=$"View edit and execute the software installation and removal queues"
  U_HELP=$"Choices for updating installed software"
  V_HELP=$"View list of installed software version information"
   TITLE=$"Software Menu"
      OK=$"Select"
  CANCEL=$"Exit"

  COMMAND=$(
  $DIALOG --item-help --ok-label "$OK" --cancel-label "$CANCEL" \
          --title "$TITLE" --menu "" 0 0 0 \
          Update   "installed software" "$U_HELP" \
          Queue    "Execute, view, modify software queues" "$Q_HELP" \
          Snapshot "View snapshot of installed software" "$V_HELP" \
          Remove   "installed software" "$D_HELP" \
          Select   "available software for both installation and removal" "$S_HELP" \
          Install  "available software" "$C_HELP" )
 do
  case $COMMAND in
   Remove)   remove_spells ;;
   Select)   select_spells ;;
   Queue)    queue_menu    ;;
   Update)   update_menu   ;;
   Install)  add_spells    ;;
   Snapshot) snapshot | column -t | ${PAGER:-less} ;;
  esac
 done
}


installed_ratio(){

 local AROF IROF CONFIGURED

 if   [[ -d $CONFIG_LOGS/$1 ]]
 then CONFIGURED=Y
 else CONFIGURED=N
 fi

 AROF=$(   echo $1 | arof | wc -l )
 IROF=$( ( echo $1 | arof; show_installed ) |
         LC_ALL=C sort | uniq -d | wc -l
       )

 if   (( IROF < 10  )); then IROF="  $IROF"
 elif (( IROF < 100 )); then IROF=" $IROF"
 fi

 if   (( AROF < 10  )); then AROF="$AROF  "
 elif (( AROF < 100 )); then AROF="$AROF "
 fi

 echo -n "$IROF/$AROF $CONFIGURED  "
}


stat_key(){
 if spell_installed $1; then echo -n "Installed  "
                        else echo -n "Available  "
 fi
}


make_menu_entry(){
 if [ -f "$VERSION_INDEX/$1" ]; then return; fi
 echo              "$1"
 installed_ratio   "$1"
 trait_of      "$1"
 short_description "$1"
}


make_generic_menulist(){
 cd $GMENU_CACHE
 while read SPELL; do
  echo    "$SPELL"
  if   ! [[ -f                    $SPELL ]]
  then make_menu_entry "$SPELL" > $SPELL
  fi
 done | xargs -r --max-lines=64 cat 2>/dev/null
}


generic_menu(){
 local MENU="/tmp/.menu.$RANDOM$RANDOM"

 ( echo "--title";        echo "$1"
   echo "--ok-label";     echo "$2"
   echo "--cancel-label"; echo "$3"
   echo "--item-help"
   echo "--menu";         echo "$4"
   echo "18"; echo "72";  echo "10"
   make_generic_menulist
 ) | sed 's:^:":;s:$:":' > $MENU

 if   $DIALOG --file $MENU
 then rm $MENU
 else rm $MENU; false
 fi
}


update_menu(){

 while
  A_HELP=$"Update installed software now by executing augur sync"
  R_HELP=$"Rebuild software installed longer than specified amount of days"
  B_HELP=$"Recompile and re-install all installed software"
   TITLE=$"Update Menu"
    HELP="Installed software can also be updated
by using the augur comand line utility.
Run augur without parameters to view the help screen"

      OK=$"Select"
  CANCEL=$"Exit"

  COMMAND=$(
  $DIALOG --item-help --ok-label "$OK" --cancel-label "$CANCEL" \
          --title "$TITLE" --menu "$HELP" 0 0 0 \
          Now     "" "$A_HELP" \
          Refresh "" "$R_HELP" \
          Rebuild "" "$B_HELP" )

 do
  case $COMMAND in
   Now)		exec augur sync	;;
   Rebuild)	rebuild		;;
   Refresh)	refresh		;;
  esac
 done
}


grep_install_logs(){
 if WHAT=$( $DIALOG --inputbox "Please enter full path and name of file" 0 0 )
 then
  cd $INSTALL_INDEX
  grep "$WHAT\$" * | $PAGER
 fi
}


set_email(){
 if SORCERER=$(
  $DIALOG --ok-label Commit --inputbox \
  "Please enter the email address that should receive reports from this box." \
  0 0 "$SORCERER" )
 then
  sed -i   '/SORCERER=/d'           $LOCAL_CONFIG
  echo  "    SORCERER=$SORCERER" >> $LOCAL_CONFIG
 fi
}


set_variable(){
 local SL NL

 SL="s:$1=.*$:$1=\"$2\":"
 NL="$1=\"$2\""

 if   grep -q "$1="    $LOCAL_CONFIG
 then sed  -i "$SL"    $LOCAL_CONFIG
 else echo    "$NL" >> $LOCAL_CONFIG
 fi
}


