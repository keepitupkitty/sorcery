 for          METHOD in /usr/{local/,}libexec/sorcery/moil.d/*; do
  if   [[ -f $METHOD ]] &&
           . $METHOD    &&
       ready
  then echo -n $"Method: "; echo "${METHOD##*/}"; begin; return
  fi
