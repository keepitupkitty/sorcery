export TEXTDOMAIN=${0##*/}
export TEXTDOMAINDIR=/usr/share/locale

# /usr/libexec/sorcery/moil must be mode 700
# for use with immune-security-tomoyo

aiq(){   [ -f "$1" ] || [ -f "$2" ] || [ -f "$3" ]; }
iq(){    aiq "$2"/{,active/,done/}"$1" || echo -n > "$2/$1"; }
iqs(){   s="$1"; while iq "$s" "$2"; [ -n "$3" ]; do shift; done; }
bury(){  while read s; do [ -f "$INSTALL_INDEX/$s" ] && iqs "$s" "$@"; done; }
vrun(){  if [ -z "$VERSION" ]; then spell_in_grimoire; run_details; fi; }
wake(){  vrun; echo "$SPELL"; loop find_providers "$SPELL" ${HOLD[*]}; }
dead(){  mkdir_p "$@"; wake | bury "$@"; }
blaze(){ sync; dead "$SAVE_QUEUE" "$REAP_QUEUE"; }
pwall(){ if [[ -n $IWALL ]]; then wall "$IWALL"; fi; }
cheer(){ message "${COLOR_MESSAGE}Moil Success${COLOR_DEFAULT}"; }
birth(){ pwall; cheer; blaze; }

gather_docs(){
 if ! [ ${FEATURE[docs]} ]; then return; fi
 if ! [[ -d $BUILD_DIR  ]]; then return; fi

 local            DOC_DIR="$DESTDIR/usr/share/doc/$SPELL"
 mkdir -pvm 755 "$DOC_DIR"

 cd $BUILD_DIR
 cp -rt "$DOC_DIR" HOWTO*  NEWS*    COPYING* Change* AUTHOR* \
                   README* INSTALL* FAQ*     CHAN*   doc*    \
                   DOC*    Doc*     conf     SETUP   LICENSE* 2>/dev/null
 cp *doc *rc "$DOC_DIR" 2>/dev/null
}

xz_manpages(){
 if   [ -n "$DESTDIR" ]
 then find "$DESTDIR"/usr{,/share}/man -type f -size +4k 2>/dev/null |
      grep "\.[0-9]$" | xargs -r xz
 fi
}

omit_infopages(){
 if   [  -n  "${FEATURE[omit_info]}" ]
 then rm -fr "$DESTDIR"/usr{,/share}/info
 fi
}

install_etc_ln(){
 if [[ -z $2 ]]; then return; fi
 local D="$DESTDIR/etc/$1"; shift
 mkdir -pvm 755 "$D"
 while [[ -n $1 ]]; do ln -s "$1" "$D"/; shift; done
}

install_shell(){ install_etc_ln shells.d $SHBIN; }
install_wm(){    install_etc_ln X11/wm   $WMBIN; }

moil_install_conf(){
 local N=700 M=$1 F=$2 D=${3:-$2}

 [[ -d  $SCRIPT_DIR/$F ]] || return
 mkdir -pvm 755 "$DESTDIR/etc/$D"
 find  "$SCRIPT_DIR/$F" -maxdepth 1 -mindepth 1 -type f |
 while read; do
  if   [ "$D" == init.d ] &&
       grep -q "# Default-Mode:"          $REPLY &&
       N=$( sed "s/# Default-Mode: //p;d" $REPLY ) 
  then install  -vm $N  -o root  -g root  $REPLY  "$DESTDIR/etc/$D"
  else install  -vm $M  -o root  -g root  $REPLY  "$DESTDIR/etc/$D"
  fi
  if   [[ -f             /etc/$D/${REPLY##*/} ]]; then
   chmod -v --reference "/etc/$D/${REPLY##*/}" \
                "$DESTDIR/etc/$D/${REPLY##*/}"
  fi
 done
}

install_pam_confs(){       moil_install_conf 644      pam.d; }
install_xinetd_confs(){    moil_install_conf 600   xinetd.d; }
install_services_confs(){  moil_install_conf 600 services.d; }
install_modprobe_confs(){  moil_install_conf 600 modprobe.d; }
install_inits(){           moil_install_conf 400 init.d
                           moil_install_conf 600 init.d/conf
                           moil_install_conf 510 init.d.on      init.d
                           moil_install_conf 600 init.d.on/conf init.d/conf; }
install_bash_completion(){ moil_install_conf 755 bash.d/interactive
                           moil_install_conf 755 bash.d/noninteractive; }

install_tomoyo_confs(){
 if ! [ -d      "$SCRIPT_DIR"/tomoyo ]; then return 0; fi
 mkdir -pm 755 "$DESTDIR"/etc/tomoyo
 find           "$SCRIPT_DIR"/tomoyo -mindepth 1 -printf "%P\n" |
 tar -C         "$SCRIPT_DIR"/tomoyo --exclude-vcs --no-recursion -cPT - |
 tar -C        "$DESTDIR"/etc/tomoyo -pxf -
}

moil_bg(){ moil &>/dev/null & disown; }

