   LOAD_QUEUED=$( queued "$LOAD_QUEUE"        | wc -l )
#    LOAD_DONE=$( loaded                      | wc -l )
     LOAD_DONE=-
   MOIL_QUEUED=$( queued "$MOIL_QUEUE"        | wc -l )
   MOIL_ACTIVE=$( queued "$MOIL_QUEUE/active" | wc -l )
#    MOIL_DONE=$( recent_pass_cast            | wc -l )
     MOIL_DONE=-
   REAP_QUEUED=$( queued "$REAP_QUEUE"        | wc -l )
   REAP_ACTIVE=$( queued "$REAP_QUEUE/active" | wc -l )
#    REAP_DONE=$( recent_void                 | wc -l )
     REAP_DONE=-
   SAVE_ACTIVE=$( queued "$SAVE_QUEUE/active" | wc -l )
   SAVE_QUEUED=$( queued "$SAVE_QUEUE"        | wc -l )
     SAVE_DONE=$( queued "$SAVE_QUEUE/done"   | wc -l )
   SIGN_ACTIVE=$( queued "$SIGN_QUEUE/active" | wc -l )
   SIGN_QUEUED=$( queued "$SIGN_QUEUE"        | wc -l )
