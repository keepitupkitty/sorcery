 }

 sorcery_mo_han(){
  local      FREE BLOCKS PERCENT
  LC_ALL=C grep -q  $SOURCE_DIR /proc/mounts &&
  stat -fc "%f %b"  $SOURCE_DIR 2>/dev/null |
  while read FREE BLOCKS; do
        (( PERCENT = 100 - FREE * 100 / BLOCKS ))
   if   (( PERCENT > 49 ))
   then echo "sorcery: $PERCENT% full"
   fi
  done
 }

 show_temp_acad(){
  acad(){
   if [ -f /proc/acpi/ac_adapter/*/state ]; then
    read < /proc/acpi/ac_adapter/*/state
    [ "${REPLY// /}" == "state:on-line" ]
   fi
  }

  if [ -f /proc/acpi/thermal_zone/*/temperature ]; then 
   read < /proc/acpi/thermal_zone/*/temperature
   echo -n "${REPLY##*  } "
  fi

  if ! [ -f /proc/acpi/ac_adapter/*/state ]; then return; fi
  if ! acad; then echo -n DC; fi
 }


 show_current(){
  show_waiting
  show_load 2>/dev/null
  show_moiling
  echo
  sorcery_mo_han
 }


 scry_output(){
  while :; do
   get_counts

   clear

   show_recent

   while ! read_key 10     &&
         ! [[ -f $EVENT ]] &&
         (( NEXT > SECONDS ))
   do :; done

   case $REPLY in
    q) return ;;
    M) augur scry-menu ;;
   esac

   if [[ -f $EVENT   ]]; then rm -f $EVENT; fi

   (( NEXT = SECONDS + 300 ))

   if   (( LOAD_QUEUED == 0 )) &&
        (( MOIL_QUEUED == 0 )) &&
        (( POST_QUEUED == 0 )) &&
        (( REAP_QUEUED == 0 )) &&
        (( WANE_QUEUED == 0 ))
   then return
   fi
  done
 }


 loop_scry(){
  SCRY_START=$( date +%s )
  local NEXT=0
  scry_output
  get_date
 }

 watch(){

  plain_less(){
   unset REPLY
   kill -15 $!
   less "$LOG"
   tail -n +1 --pid=$$ -f -s 0.1 "$LOG" &
  }

  fancy_less(){
   unset REPLY
   kill -15 $!
   less +F "$LOG"
   tail -n +1 --pid=$$ -f -s 0.1 "$LOG" &
  }

  report_default_config_changes(){
   local         DIF="$ETC_LOGS/$1/diff"
   if   [[ -f   $DIF ]] &&
        [[ -s   $DIF ]]
   then report "$DIF" $"Differences in default configurations detected for $1"
   fi
  }


  local WAIT_MSG=$"Waiting for compilation of $1 to begin"
  local  NOT_MSG=$"is neither queued nor processing."
  local      LOG="$CLOG_DIR/$1"
  local SKIP_MSG=$"
Press l to switch to less view of compile log.
Press q to quit augur scry."

  if   ! [[ -f $LOAD_QUEUE/active/$1 ]] && ! [[ -f $LOAD_QUEUE/$1 ]] &&
       ! [[ -f $MOIL_QUEUE/active/$1 ]] && ! [[ -f $MOIL_QUEUE/$1 ]]
  then sleep 3
  fi

  if   [[ -f $LOAD_QUEUE/$1 ]] || [[ -f $LOAD_QUEUE/active/$1 ]]
  then watch_load "$1"
  fi

  if   ! [[ -f $MOIL_QUEUE/$1 ]] &&
       ! [[ -f $MOIL_QUEUE/active/$1 ]]
  then message "${COLOR_PROBLEM}$1 $NOT_MSG"; return 1
  fi

  if     ! [[ -f $LOG ]]; then
   echo "$WAIT_MSG"
   echo "$SKIP_MSG"

   while [[ -f $MOIL_QUEUE/$1 ]] &&
       ! [[ -f $LOG ]] &&
       ! [[ $REPLY == q ]]
   do  read_key
   done
  fi
 
  if   [[ $REPLY == q ]];                then return
  elif ! locked "$MOIL_QUEUE/active/$1"; then read_key
  fi

  if     [[ -f $LOG ]]; then
   tail  -n +1 --pid=$$ -f -s 0.1 "$LOG" &
   while [[ -f $LOG ]] &&
         locked "$MOIL_QUEUE/active/$1" &&
         ! [[ $REPLY == q ]]
   do
    read_key
    case  $REPLY  in
     l) plain_less ;;
     L) fancy_less ;;
     q) break      ;;
    esac
   done
  fi

  if   ! [[ $REPLY == q ]]
  then report_default_config_changes
  fi
 }

 # This is where the scry function begins
 current_index
 clear
 if   [[ -n  $1 ]]
 then watch "$1"
 else loop_scry
 fi
}
