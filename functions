check_tar(){
 local  FROM="$1"
 local  REPLY
 compressor "$FROM"
 case "$REPLY" in
  7z)    7za t -so "$FROM" ;;
  lz)    lzip  -ct "$FROM" ;;
  bzip2) bzip2 -ct "$FROM" ;;
  gzip)  gzip  -ct "$FROM" ;;
  lzma)  lzma  -ct "$FROM" ;;
  xz)    xz    -ct "$FROM" ;;
  *)     false ;;
 esac
}

untar(){
 if ! is_comp_src "$1"; then return 0; fi; uncomp_name "$1"
 if   [[ -d $REPLY ]];  then return 0; fi
 if   [[ -z $REPLY ]];  then return 0; fi

 local FROM="$1"
 local TO="$REPLY"
 local TMP="$TO.new.$RANDOM$RANDOM"

 comp_tar_i(){
  local O="--no-same-owner"
  local P="--no-same-permissions"
  if ! "$@"                      ; then rm -fr "$TMP"; return 1; fi |
  if ! tar $O $P -C "$TMP" -ixf -; then rm -fr "$TMP"; return 1; fi
 }

 comp_tar(){
  # Starting with KDE version 4.8.2
  # KDE's source tarballs contain trailing garbage
  # that causes tar to exit with error code 2
  # when invoked with the -i parameter
  # This is a bad hack because of KDE's buggy tarballs.
  mkdir -p "$TMP"
  local O="--no-same-owner"
  local P="--no-same-permissions"
  "$@" | if ! tar $O $P -C "$TMP" -xf -; then rm -fr "$TMP"; return 1; fi
 }

 zip(){ unzip -qo  "$FROM" -d "$TMP" &>/dev/null; }

 rpm(){
  if ! rpmunpack < "$FROM"; then rm -fr "$TMP"; fi |
  if ! gzip -cd;            then rm -fr "$TMP"; fi |
  if !                           cd     "$TMP"     ||  
     ! cpio -idm;           then rm -fr "$TMP"; fi
 }

 ut(){
  local REPLY
  mkdir -p "$TMP"
  compressor "$FROM"
  case "$REPLY" in
   xz)    comp_tar_i xz    -cd "$FROM" || comp_tar xz    -cd "$FROM" ;;
   bzip2) comp_tar_i bzip2 -cd "$FROM" || comp_tar bzip2 -cd "$FROM" ;;
   gzip)  comp_tar_i gzip  -cd "$FROM" || comp_tar gzip  -cd "$FROM" ;;
   tar)   comp_tar_i cat       "$FROM" || comp_tar cat       "$FROM" ;;
   7z)    comp_tar_i 7za x -so "$FROM" || comp_tar 7za x -so "$FROM" ;;
   lzma)  comp_tar_i lzma  -cd "$FROM" || comp_tar lzma  -cd "$FROM" ;;
   lz)    comp_tar_i lzip  -cd "$FROM" || comp_tar lzip  -cd "$FROM" ;;
   zip)   zip ;;
   rpm)   rpm ;;
  esac &>/dev/null

  rmdir     "$TMP" 2>/dev/null
  if  [ -d  "$TMP" ]; then
   rm -fr    "$TO"
   mv "$TMP" "$TO"
  else false
  fi
 }

 if ut || ut; then return; fi

 if   check_tar "$FROM"
 then event "$SPELL" "$VERSION" "Fail Cast" "Insufficient space"
 else event "$SPELL" "$VERSION" "Fail Cast" "Corrupt$TAB$FROM"; rm -f "$FROM"
 fi
 return 1
}

compressor(){
        REPLY="$( file -bk "$1" )"
 case "$REPLY" in
        bzip2*) REPLY=bzip2 ;;
         gzip*) REPLY=gzip  ;;
           xz*) REPLY=xz    ;;
           XZ*) REPLY=xz    ;;
        *lzip*) REPLY=lz    ;;
  *7z*|*7-zip*) REPLY=7z    ;;
        *lzma*) REPLY=lzma  ;;
    *compress*) REPLY=gzip  ;;
         *tar*) REPLY=tar   ;;
         *RPM*) REPLY=rpm   ;;
         *Zip*) REPLY=zip   ;;
        *HTML*) REPLY=html  ;;
        *SGML*) REPLY=sgml  ;;
         *XML*) REPLY=xml   ;;
 esac
}

decomp(){
 local  REPLY
 compressor "$1"
 case "$REPLY" in
     7z) 7za   x -so "$1" 2>/dev/null ;;
     lz) lzip    -cd "$1" ;;
  bzip2) bzip2   -cd "$1" ;;
   gzip) gzip    -cd "$1" ;;
   lzma) lzma    -cd "$1" ;;
     xz) xz      -cd "$1" ;;
      *) cat         "$1" ;;
 esac
}

decompress(){ decomp "$@"; }

is_comp_tar(){
 decomp "$1" 2>/dev/null |
 LC_ALL=C dd bs=1024 count=1 2>/dev/null |
 LC_ALL=C file -b - |
 LC_ALL=C grep -q tar
}

is_comp_src(){
 decomp "$1" 2>/dev/null |
 LC_ALL=C dd bs=1024 count=1 2>/dev/null |
 LC_ALL=C file -b - |
 LC_ALL=C grep -q "tar\|Zip"
}

