 mkdir_p "$1"
 basenames |
 if   [[ -n $WHEN ]]
 then sed "s:^:$1/:" | xargs -r --max-lines=256 touch -t $WHEN
 else sed "s:^:$1/:" | xargs -r --max-lines=256 touch -a
 fi

 if   [[ $1 =~ $CAST_QUEUE ]]
 then queue_fill_load
 fi
}

