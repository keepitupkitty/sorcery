sufficient_sub(){
 local f s ss

 case "$3" in
  Source)
   ss="$(
     find "$MOIL_QUEUE/${SPELL:-EMPTY}" \
          "$MOIL_QUEUE/active/"     \
          -mindepth 1 -maxdepth 1   \
          -type f -printf '%f\n' 2>/dev/null | sort -u )" ;;
  Post)
   ss="$(
     find "$MOIL_QUEUE/${SPELL:-EMPTY}" \
          "$MOIL_QUEUE/active/"     \
          "$POST_QUEUE/"            \
          -mindepth 1 -maxdepth 1   \
          -type f -printf '%f\n' 2>/dev/null | sort -u )" ;;
  Ccache)
   ss="$(
     find "$MOIL_QUEUE/${1:-EMPTY}" \
          "$MOIL_QUEUE/active/"     \
          "$RUSH_QUEUE/done/"       \
          -mindepth 1 -maxdepth 1   \
          -type f -printf '%f\n' 2>/dev/null | sort -u )" ;;
 esac

 for s in $ss; do
  f="$( recent_max_stat "$s" "$3" )" || continue

  (( t -= f ))
  (( t += $( used_megabytes "$1/$s" ) ))
 done
}

