queued(){
 ima(){ ! [[    $1 -nt /proc/version ]]; }
 mika(){  [[ -f $1                   ]]; }

 local REP
 local RETURN='REPLY=""; return 1'

 if   [[ $1 == check ]]
 then local RESPONSE='return'; shift
 elif [[ $1 == REPLY ]]
 then                          shift
      local RESPONSE='REP+="${FILE##*/}$LF"; RETURN="return"'; REPLY="${REP%$LF*}";
 else local RESPONSE='echo "${FILE##*/}";    RETURN="return"'
 fi

 if   ! [[ -d $1 ]]
 then REPLY=""; return 1
 fi

 local        FILE
 for          FILE in $1/*; do
  if   mika "$FILE" &&
       ima  "$FILE"
  then eval $RESPONSE
  fi
 done

 REPLY="${REP%$LF*}"
 eval $RETURN
}

