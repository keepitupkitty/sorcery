# alien     files and directories that are know to be alien
# alien     files and directories are not undesirable aliens
# immutable files and directories can not be reaped
# protected files and directories can not be reaped
# omit      files and directories will not be tracked nor owned
# exclude   files and directories will not be tracked nor owned
# vary      files and directories md5sums will not be recorded
# vary      modified configuration files are not preserved across updates

add_source(){
 local name pro tag

 adds(){
  local REPLY=()
  while [[ -z ${1##*/} ]] && REPLY+=( "$1" ); [[ -n $2 ]]; do shift; done

     TAG+=( "$tag" )
  SOURCE+=( "$SOURCE_CACHE/$SPELL/$VERSION/${name:-${1##*/}}" )
  if    [[ -n $REPLY ]]
  then  USOURCE+=( "${REPLY[@]/%/$1}" )
  else  USOURCE+=(              "$1"  )
  fi
 }

 if ! [[ $1 =~ / ]]; then  pro="$1"; shift 1
 if ! [[ $1 =~ / ]]; then name="$1"; shift 1
 if ! [[ $1 =~ / ]]; then  tag="$1"; shift 1; else tag=master; fi
 fi; else pro=stable; fi

 if   [[ $pro   == $PROGRESSV ]]; then adds "$@"
 elif [[ custom == $PROGRESS  ]] &&
      [[ $pro   == stable     ]]; then adds "$@"
 fi
}

source(){
 if    [ -f $SOURCE_LOGS/$SPELL ]; then
  if   [ -z "$USOURCE" ]
  then eval add_source $(< $SOURCE_LOGS/$SPELL )
  fi
 else
  add_source "$@"
 fi
}

