}

wait_index(){
 if  [[           -f $REFRESH_INDEX ]]; then declare -i LIM
     LIM=$( finfo -m $REFRESH_INDEX 2>/dev/null );
  (( LIM+=60 ))

  while [[        -f $REFRESH_INDEX ]]
  do    finfo     -m /proc/version
        sleep 1
  done  |
  while read && (( LIM > REPLY ))
  do    :
  done

  [[              -f $REFRESH_INDEX ]] &&
  (( $( finfo     -m $REFRESH_INDEX ) + 60 <
     $( finfo     -m /proc/version  )
  )) &&
  rm              -f $REFRESH_INDEX
 fi
}

