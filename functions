# Functions for automatically filling a VERSION array with descending dates
# First and only parameter is number of elements in the VERSION array

load_date(){
 [[ -z $DATE ]] || return
 local IFS="$STANDARD_IFS"
 read -a DATE <<< $( date -u "+%Y %m %V %j" )
# year month week day
}

version_year_day(){
 leap_year(){
    (( $1 % 4   == 0 )) &&
  ! (( $1 % 100 == 0 )) ||
    (( $1 % 400 == 0 ))
 }

 year_days(){
  if   leap_year $1
  then DAY=366
  else DAY=365
  fi
 }

 kyonen(){
  if   (( DAY == 0 ))
  then (( YEAR-- )); year_days $YEAR
  fi
 }

 vyd(){
  RUN=${1:-31}; (( RUN++ ))

  load_date
  YEAR=${DATE[0]}
  DAY=${DATE[3]}
  DAY=${DAY##0}
  DAY=${DAY##0}

  if   [[ -n    $2 ]]
  then (( DAY-= $2 ))
  fi

  while (( RUN > 0 )); do
   kyonen
   echo "$YEAR-$DAY"
   (( DAY-- ))
   (( RUN-- ))
  done
 }
 version stable $( vyd "$@" )
}

version_year_week(){

 kyonen(){
  if   (( WEEK == 0 ))
  then (( WEEK = 53 ))
       (( YEAR--    ))
  fi
 }

 vyw(){
  load_date
  YEAR=${DATE[0]}
  WEEK=${DATE[2]}
  WEEK=${WEEK##0}

  RUN=${1:-0}; (( RUN++ ))

  while (( RUN > 0   )); do echo "$YEAR-$WEEK"
        (( RUN--     ))
        (( WEEK--    )); kyonen
  done
 }

 version stable $( vyw "$@" )
}

version_year_month(){
 
 kyonen(){
  if   (( MONT == 0 ))
  then (( MONT = 12 ))
       (( YEAR--    ))
  fi
 }

 vym(){
  load_date
  YEAR=${DATE[0]}
  MONT=${DATE[1]}
  MONT=${MONT##0}

  RUN=${1:-0}; (( RUN++ ))

  while (( RUN > 0   )); do echo "$YEAR-$MONT"
        (( RUN--     ))
        (( MONT--    )); kyonen
  done
 }

 version stable $( vym "$@" )
}

