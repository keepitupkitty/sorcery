   repo "$@"
   if ! [[ $1 =~ / ]]; then  pro="$1"; shift 1
   if ! [[ $1 =~ / ]]; then name="$1"; shift 1
   if ! [[ $1 =~ / ]]; then            shift 1; fi; fi
                       else pro=stable; fi

   if     [[ -f $SOURCE_LOGS/$SPELL ]]; then
    read <     "$SOURCE_LOGS/$SPELL"; eval "printf \"$p$REPLY\n\""
   elif   [[ $pro   == $PROGRESSV ]]; then
    while [[ -n $2 ]]; do shift; done; printf "$p${name:-${1##*/}}\n"
   elif   [[ custom == $PROGRESS  ]] &&
          [[ $pro   == stable     ]]; then
    while [[ -n $2 ]]; do shift; done; printf "$p${name:-${1##*/}}\n"
   fi
  }

 inherit(){
  echo "parent$TAB$1$TAB$SPELL"
  if   [[ -f $GRIMOIRE/$1 ]]
  then     . $GRIMOIRE/$1
  else
   echo "Spell $SPELL unable to inherit" 1>&2
   echo "Spell $1 not found in the $GRIMOIRE" 1>&2
  fi
