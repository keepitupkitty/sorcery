  LC_ALL=C touch -d "$( LC_ALL=C date -u -d "23:59:59" )" $TOMORROW
  view_index "trait${TAB}stale" $INDEX |
  sed        "s:^:$GRIMOIRE/:"       |
  xargs      -r --max-lines=64 touch -c
 else return  1
 fi
}

