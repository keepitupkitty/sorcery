normalize_date(){
 # Accepts a future date in "$1"
 # returns a proper normalized date in $REPLY

 adjust_month(){
  declare -i LIM
  case $MON in
    1) LIM=31 ;;
    2) LIM=28; (( YEAR % 4 == 0 )) &&  (( LIM++ )) ;;
    3) LIM=31 ;;
    4) LIM=30 ;;
    5) LIM=31 ;;
    6) LIM=30 ;;
    7) LIM=31 ;;
    8) LIM=31 ;;
    9) LIM=30 ;;
   10) LIM=31 ;;
   11) LIM=30 ;;
   12) LIM=31 ;;
  esac
  if (( DAY > LIM )); then (( DAY-=LIM )); (( MON++ )); fi
 }    

 declare -i YEA="${1:0:4}";  [ "${1:4:1}"  == 0 ] &&
 declare -i MON="${1:5:1}"                        ||
 declare -i MON="${1:4:2}";  [ "${1:6:1}"  == 0 ] &&
 declare -i DAY="${1:7:1}"                        ||
 declare -i DAY="${1:6:2}";  [ "${1:8:1}"  == 0 ] &&
 declare -i HOU="${1:9:1}"                        ||
 declare -i HOU="${1:8:2}";  [ "${1:10:1}" == 0 ] &&
 declare -i MIN="${1:11:1}"                       ||
 declare -i MIN="${1:10:2}"; [ "${1:13:1}" == 0 ] &&
 declare -i SEC="${1:14:1}"                       ||
 declare -i SEC="${1:13:2}"

 if (( SEC > 59 )); then (( SEC-=60 )); (( MIN++ )); fi
 if (( MIN > 59 )); then (( MIN-=60 )); (( HOU++ )); fi
 if (( HOU > 23 )); then (( HOU-=24 )); (( DAY++ )); fi
 if (( MON > 12 )); then (( MON-=12 )); (( YEA++ )); fi
 if (( DAY > 28 )); then adjust_month;               fi
 if (( MON > 12 )); then (( MON-=12 )); (( YEA++ )); fi

 REPLY="$YEA";   (( MON > 9  )) &&
 REPLY+="$MON"                  ||
 REPLY+="0$MON"; (( DAY > 9  )) &&
 REPLY+="$DAY"                  ||
 REPLY+="0$DAY"; (( HOU > 9  )) &&
 REPLY+="$HOU"                  ||
 REPLY+="0$HOU"; (( MIN > 9  )) &&
 REPLY+="$MIN"                  ||
 REPLY+="0$MIN"; (( SEC > 10 )) &&
 REPLY+=".$SEC"; (( SEC > 0  )) &&
 REPLY+=".0$SEC"
}


