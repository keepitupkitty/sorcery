find_source(){
 if [[ -z $1 ]]; then             return 1; fi
 if [[ -f $1 ]]; then REPLY="$1"; return 0; fi

 local TAR="${1##*/}"; tarname "$TAR"; TAR="$REPLY"
 local DIRS="${1%/*}"; [[ -d $DIRS ]] || DIRS=""

 while [[ -n $2 ]]; do DIRS+="$TAB$2"; shift; done

 DIRS="${DIRS:-$SOURCE_CACHE}"

 REPLY="$(
  find ${FIND_FOLLOW_SYMBOLIC_LINKS} $DIRS -type f -not -empty 2>/dev/null |
  sed  -n    "\,/$TAR[^/]*\$,p
              \,/${TAR/%\.tar/.tgz}\$,p" |
  head -n 1 )"

