 parent_check(){
  [[ -d $SPELL_INDEX ]] &&
  find  $SPELL_INDEX -type f |
  xargs -r --max-lines=2048 cat |
  sed   -n 's:^parent\t::p' |
  while read           PARENT                   PROGENY; do
   if   [[  $GRIMOIRE/$PARENT -nt $SPELL_INDEX/$PROGENY ]]
   then echo                        "$GRIMOIRE/$PROGENY"
   fi
  done |
  xargs -r --max-lines=2048 touch
 }

 idx_per(){
  if    (( IDX_START <  SECONDS ))
  then  (( IDX_START =  SECONDS + 5 ))
   if   (( IDX_TOTAL == 0       ))
   then (( IDX_TOTAL =  IDX_NUM ))
   fi

   (( IDX_PER = 100 - IDX_NUM * 100 / IDX_TOTAL ))
   echo -en "\rIndexing  $IDX_PER%" 1>&2
   echo -n >$REFRESH_INDEX
  fi
 }

 run_spells(){
  cd $GRIMOIRE
  while read IDX_NUM SPELL
  do index_spell > $SPELL_INDEX/$SPELL; idx_per
  done
 }

 run_spells_time(){
  local      PROGRESS VERSION
  typeset -a REQ SOURCE

  TIMEFORMAT=%R
  cd $GRIMOIRE
  while read IDX_NUM SPELL
  do echo -n "$SPELL " 1>&2
     time index_spell > $SPELL_INDEX/$SPELL; idx_per
  done
 }

 only_newer(){
  cd $GRIMOIRE
  while read; do
   if [[ $REPLY -nt $SPELL_INDEX/$REPLY ]]
   then echo "$REPLY"
   fi
  done
 }

 declare -i IDX_NUM IDX_PER IDX_START IDX_TOTAL=0
 declare -A PMAP

 set +f
 for NOW in $PROVIDE_LOGS/*; do
  if  [[ -f $NOW ]]; then
   read < $NOW
   PMAP[${NOW##*/}]="$REPLY"
  fi
 done
 set -f

 (( IDX_START = SECONDS - 1 ))

 if [[ -d $SPELL_INDEX ]]; then
  mkdir -p $SPELL_INDEX $REQ_INDEX $OPT_INDEX

  parent_check

  find ${FIND_FOLLOW_SYMBOLIC_LINKS} $GRIMOIRE \
       -maxdepth 1 -type f \
       -perm ${FIND_PERM_ANY}0500 -printf "%P\n" |
  only_newer | /bin/cat -n | tac | run_spells

 else
  mkdir -p $SPELL_INDEX $REQ_INDEX $OPT_INDEX

  find ${FIND_FOLLOW_SYMBOLIC_LINKS} $GRIMOIRE \
       -maxdepth 1 -type f \
       -perm ${FIND_PERM_ANY}0500 -printf "%P\n" |
  /bin/cat -n | tac | run_spells

 fi

 find $REQ_INDEX $OPT_INDEX -type f -empty |
 xargs -r --max-lines=2048 rm

 touch $MIRROR_INDEX
)
}

