# pipe allows stdin to continue flowing when
# calling functions that normally do not read stdin

pipe(){ cat -; "$@"; }
loop(){ local p="$1"; while "$p" "$2"; [ -n "$3" ]; do shift; done; }

# multi can be used to repeatedly call another
# function acts only upon "$1"

multi(){
 local FUNC="$1"
 shift
 while [[ -n $1 ]]
 do   $FUNC "$@"; shift
 done
}

# convp = convert pipe to parameter
# convp converts the contents of stdin
# to parameters for the following command.
# convp is to functions as
# xargs is to executables.

convp(){ "$@" $( cat - ); }

safe_sync(){ sync; }

event(){
 local SPL="$1"; shift
 local VER="$1"; shift
 local EV="$1";  shift
 local NAME="$SPL$TAB$( date +%Y%m%d%H%M%S )$TAB$VER$TAB$EV"
 local LOG="$EVENT_LOGS/$NAME"
 local IND="$EVENT_INDEX/$NAME"

 if [[ -n $SPL ]] && [[ -n $VER ]] && [[ -n $EV  ]];  then
  mkdir_p  "$EVENT_LOGS"

  if    [[ -n $1 ]]; then
   if   [[ -f $1 ]]
   then cat  "$1" >> "$LOG"
   elif [    "$1" == - ]
   then cat -     >> "$LOG"
   else echo "$@" >> "$LOG"
   fi
  else
   echo -n   >> "$LOG"
  fi
  echo -n  >> "$IND"
  chmod 644 "$LOG" "$IND"
 fi
 return 0
}

dvent(){
 local SPL="$1"
 shift

 if [[ -z $SPL ]]; then return; fi

 if         [[ -z $1 ]]; then find "$EVENT_LOGS" "$EVENT_INDEX" -type f -perm -0040
 else while [[ -n $1 ]]; do   find "$EVENT_LOGS" "$EVENT_INDEX" -type f -perm -0040 |
                         LC_ALL=C grep "$TAB$1$" ; shift; done
 fi | 
 LC_ALL=C grep "/$SPL$TAB" |
 escape_qs | xargs -r --max-lines=256 chmod 604
}

