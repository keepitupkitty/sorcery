# locked() returns true if any of it's parameters,
# or locked's piped input when no parameters are present,
# leads to a file that contains a current PID.
# Otherwise locked() returns false.

locked(){
 if   [ -z "$1" ]; then while read; do locked "$REPLY" && return; done; return 1
 elif any_dir "$@"; then find "$@" -type f -not -empty | locked; return
 fi

 local C

 while [ -f "$1" ] || return 1
       C="${1%/*}"; C="${C%/*}"; C=${C##*/}
       tumble "$C" < "$1" && return
       [ -n "$2" ]
 do    shift; done; return 1
}

