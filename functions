stale_locks(){
 if   ! [ -d "${QUEUE_DIR:=/aux/run/queue/}" ]; then return; fi

 # eliminate stale PID files from queue
 find "$QUEUE_DIR/"*/{active,build,busy} -type f -not -empty 2>/dev/null |
 while read; do locked "$REPLY" || rm -f "$REPLY"; done

 # eliminate misspelled spells from queue
 find "$QUEUE_DIR" -type f 2>/dev/null |
 while read; do
  if ! [[ -f $VERSION_INDEX/${REPLY##*/} ]] &&
     ! [[ -f      $GRIMOIRE/${REPLY##*/} ]] &&
     ! [[ -f  $CURRENT_LOGS/${REPLY##*/} ]] &&
     ! [[ active ==         ${REPLY##*/} ]]
  then rm -f "$REPLY"
  fi
 done

 # eliminate dangling symbolic links such as stale done symlinks
 find -L "$QUEUE_DIR" -type l | xargs -r --max-lines=16 rm -f
}

